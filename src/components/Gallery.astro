---
const galleryItems = [
  {
    image: "/_astro/pasta.png",
    title: "Tartufo Bianco",
    description: "Handmade tagliolini, fresh white truffle, parmigiano reggiano."
  },
  {
    image: "/_astro/pizza.png",
    title: "Margherita Verace",
    description: "San Marzano tomatoes, fresh mozzarella di bufala, basil, olive oil."
  },
  {
    image: "/_astro/dessert.png",
    title: "Tiramisù Classico",
    description: "Mascarpone, espresso-soaked ladyfingers, rich cocoa."
  }
];
---

<section class="gallery-section container" id="menu">
  <div class="gallery-header animate-fade-in">
    <span class="eyebrow">Il Menù</span>
    <h2>Culinary Masterpieces</h2>
    <p class="text-muted">Explore a selection of our most beloved and authentic dishes.</p>
  </div>
  
  <div class="gallery-grid">
    {galleryItems.map((item, index) => (
      <div class="gallery-item" style={`animation-delay: ${index * 0.15}s;`}>
        <div class="img-wrapper">
          <img src={item.image} alt={item.title} loading="lazy" />
          <div class="overlay">
            <div class="overlay-content">
              <h3>{item.title}</h3>
              <p>{item.description}</p>
            </div>
          </div>
        </div>
      </div>
    ))}
  </div>
</section>

<style>
  .gallery-section {
    padding: 6rem 0;
  }
  
  .gallery-header {
    text-align: center;
    margin-bottom: 4rem;
  }
  
  .eyebrow {
    color: var(--primary);
    font-family: var(--heading-font);
    font-size: 1.1rem;
    font-style: italic;
    display: block;
    margin-bottom: 0.5rem;
  }

  .gallery-header h2 {
    font-size: 2.5rem;
    margin-bottom: 1rem;
  }
  
  .text-muted {
    font-size: 1.1rem;
    max-width: 600px;
    margin: 0 auto;
  }

  .gallery-grid {
    display: grid;
    /* 3 columns on desktop, 1 on mobile */
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 2rem;
  }

  .gallery-item {
    border-radius: 4px;
    overflow: hidden;
    animation: fadeIn 0.8s ease-out forwards;
    opacity: 0;
  }

  .img-wrapper {
    position: relative;
    width: 100%;
    aspect-ratio: 4/5;
    overflow: hidden;
  }
  
  .img-wrapper img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s ease;
  }

  .img-wrapper:hover img {
    transform: scale(1.08);
  }

  .overlay {
    position: absolute;
    top: 0; left: 0; right: 0; bottom: 0;
    background: linear-gradient(to top, rgba(17,16,15,0.95) 0%, rgba(17,16,15,0.4) 50%, transparent 100%);
    opacity: 0;
    transition: opacity 0.4s ease;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 2rem;
  }

  .img-wrapper:hover .overlay {
    opacity: 1;
  }

  .overlay-content h3 {
    font-size: 1.5rem;
    margin-bottom: 0.5rem;
    transform: translateY(20px);
    transition: transform 0.4s ease;
  }

  .overlay-content p {
    color: var(--text-muted);
    font-size: 0.95rem;
    line-height: 1.5;
    transform: translateY(20px);
    transition: transform 0.4s ease 0.1s;
  }

  .img-wrapper:hover .overlay-content h3,
  .img-wrapper:hover .overlay-content p {
    transform: translateY(0);
  }
</style>
