---
// A simple reusable gallery component using CSS Grid and our glassmorphism styles
---

<section class="gallery-section container">
  <div class="gallery-header animate-fade-in">
    <h2>Discover Our Work</h2>
    <p class="text-muted">Explore some of our latest projects and creations.</p>
  </div>
  
  <div class="gallery-grid">
    <!-- Placeholder images that look premium -->
    <div class="gallery-item glass">
      <div class="img-wrapper"></div>
      <div class="item-content">
        <h3>Project Alpha</h3>
        <p>A stunning visual experience designed to captivate.</p>
      </div>
    </div>
    <div class="gallery-item glass" style="animation-delay: 0.1s;">
      <div class="img-wrapper"></div>
      <div class="item-content">
        <h3>Project Beta</h3>
        <p>Modern architecture meeting natural aesthetics.</p>
      </div>
    </div>
    <div class="gallery-item glass" style="animation-delay: 0.2s;">
      <div class="img-wrapper"></div>
      <div class="item-content">
        <h3>Project Gamma</h3>
        <p>Sleek and polished interfaces with vibrant colors.</p>
      </div>
    </div>
  </div>
</section>

<style>
  .gallery-section {
    padding: 6rem 2rem;
  }
  
  .gallery-header {
    text-align: center;
    margin-bottom: 4rem;
  }
  
  .gallery-header h2 {
    font-size: 2.5rem;
    margin-bottom: 1rem;
    background: linear-gradient(to right, var(--text-main), var(--text-muted));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }
  
  .text-muted {
    color: var(--text-muted);
    font-size: 1.1rem;
    max-width: 600px;
    margin: 0 auto;
  }

  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 2rem;
  }

  .gallery-item {
    border-radius: 16px;
    overflow: hidden;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    animation: fadeIn 0.8s ease-out forwards;
    opacity: 0;
  }

  .gallery-item:hover {
    transform: translateY(-8px);
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.4);
    border-color: rgba(255, 255, 255, 0.2);
  }

  .img-wrapper {
    height: 200px;
    width: 100%;
    /* A premium gradient placeholder */
    background: linear-gradient(135deg, var(--card-bg), var(--card-border));
    position: relative;
    overflow: hidden;
  }
  
  .img-wrapper::after {
    content: '';
    position: absolute;
    top: 0; left: -100%; width: 50%; height: 100%;
    background: linear-gradient(to right, transparent, rgba(255,255,255,0.05), transparent);
    transform: skewX(-20deg);
    animation: shine 3s infinite;
  }

  .item-content {
    padding: 1.5rem;
  }

  .item-content h3 {
    font-size: 1.25rem;
    margin-bottom: 0.5rem;
  }

  .item-content p {
    color: var(--text-muted);
    font-size: 0.95rem;
  }

  @keyframes shine {
    0% { left: -100%; }
    20% { left: 200%; }
    100% { left: 200%; }
  }
</style>
