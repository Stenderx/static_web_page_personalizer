---
import data from '../../assets/data.json';
import { Image } from 'astro:assets';

// Import all images from the assets folder using glob
const images = import.meta.glob('../../assets/images/*.{jpeg,jpg,png,gif}');
// Helper to find the correct image promise for the hero
const heroImagePath = `../../assets/images/${data.hero.image}`;
const heroImagePromise = images[heroImagePath];

// Extract hero copy
const { badge, headlineConfig, subtitle, buttons } = data.hero;
---

<header class="hero-section">
  {heroImagePromise && (
    <div class="hero-bg">
      <Image src={heroImagePromise()} alt="Hero Background" layout="fill" objectFit="cover" quality={80} />
    </div>
  )}
  <div class="hero-overlay"></div>
  <div class="hero-content container">
    <div class="badge animate-fade-in">
      <span>{badge}</span>
    </div>
    
    <h1 class="animate-fade-in" style="animation-delay: 0.1s;">
      {headlineConfig.line1} <br/>
      <span class="text-primary italic">{headlineConfig.line2Highlight}</span>
    </h1>
    
    <p class="subtitle animate-fade-in" style="animation-delay: 0.2s;">
      {subtitle}
    </p>

    <div class="cta-buttons animate-fade-in" style="animation-delay: 0.3s;">
      {buttons.map((btn) => (
        <a href={btn.link} class={`btn btn-${btn.style}`}>{btn.text}</a>
      ))}
    </div>
  </div>
</header>

<style>
  .hero-section {
    position: relative;
    min-height: 90vh;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    overflow: hidden;
    padding: 6rem 0;
  }
  
  .hero-bg {
    position: absolute;
    top: 0; left: 0; width: 100%; height: 100%;
    z-index: 0;
  }
  
  .hero-bg :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  
  .hero-overlay {
    position: absolute;
    top: 0; left: 0; width: 100%; height: 100%;
    /* Dark gradient overlay to ensure text readability */
    background: linear-gradient(to bottom, rgba(17, 16, 15, 0.4), rgba(17, 16, 15, 0.95));
    z-index: 1;
  }

  .hero-content {
    position: relative;
    z-index: 10;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .badge {
    padding: 0.5rem 1.5rem;
    border: 1px solid rgba(255,255,255,0.2);
    border-radius: 9999px;
    font-size: 0.8rem;
    font-family: var(--heading-font);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 2rem;
    color: var(--primary);
  }

  h1 {
    font-size: clamp(3.5rem, 8vw, 6rem);
    letter-spacing: -0.02em;
    margin-bottom: 1.5rem;
    line-height: 1.1;
  }

  .text-primary {
    color: var(--primary);
  }
  
  .italic {
    font-style: italic;
    font-weight: 400;
  }

  .subtitle {
    font-size: clamp(1.1rem, 2vw, 1.25rem);
    color: var(--text-muted);
    max-width: 600px;
    margin: 0 auto 3rem auto;
  }

  .cta-buttons {
    display: flex;
    gap: 1.5rem;
    justify-content: center;
    flex-wrap: wrap;
  }
</style>
