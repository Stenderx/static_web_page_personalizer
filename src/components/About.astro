---
---

<section class="about-section" id="about">
  <div class="container layout-grid">
    <div class="about-content animate-fade-in">
      <span class="eyebrow">La Nostra Storia</span>
      <h2>A Tradition of Excellence</h2>
      <p class="text-body">
        Since 1994, Il Sapore Autentico has been bringing the warmth, passion, and vibrant flavors of traditional Italy to the heart of the city. We believe that food is not just nourishment, but a celebration of life, family, and heritage.
      </p>
      <p class="text-body">
        Our chefs carefully source the finest seasonal ingredients, combining classic recipes with refined modern techniques to create a dining experience you won't forget.
      </p>
      <div class="signature">
        <p>Head Chef & Founder</p>
        <span class="name">Marco Rossi</span>
      </div>
    </div>

    <!-- Right side decorative elements -->
    <div class="about-images animate-fade-in" style="animation-delay: 0.2s;">
      <div class="img-wrapper highlight glass">
        <!-- Base template expects pasta.png in assets/images -->
        <img src="/_astro/pasta.png" alt="Signature Dish" loading="lazy" />
      </div>
    </div>
  </div>
</section>

<style>
  .about-section {
    padding: 8rem 0;
    position: relative;
    background: var(--bg-color);
  }

  .layout-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }

  @media (max-width: 900px) {
    .layout-grid {
      grid-template-columns: 1fr;
    }
  }

  .eyebrow {
    color: var(--primary);
    font-family: var(--heading-font);
    font-size: 1.1rem;
    font-style: italic;
    display: block;
    margin-bottom: 1rem;
  }

  h2 {
    font-size: 2.5rem;
    margin-bottom: 2rem;
  }

  .text-body {
    color: var(--text-muted);
    margin-bottom: 1.5rem;
    font-size: 1.05rem;
  }

  .signature {
    margin-top: 3rem;
    border-top: 1px solid var(--card-border);
    padding-top: 1.5rem;
  }

  .signature p {
    color: var(--text-muted);
    font-size: 0.9rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .signature .name {
    font-family: var(--heading-font);
    font-size: 1.5rem;
    color: var(--text-main);
    font-style: italic;
  }

  .about-images {
    position: relative;
    height: 100%;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .img-wrapper {
    width: 100%;
    max-width: 450px;
    border-radius: 8px;
    overflow: hidden;
    position: relative;
  }
  
  .img-wrapper img {
    width: 100%;
    height: auto;
    display: block;
    aspect-ratio: 4/5;
    object-fit: cover;
    transition: transform 0.6s ease;
  }

  .img-wrapper:hover img {
    transform: scale(1.05);
  }

  /* Decorative border */
  .img-wrapper::before {
    content: '';
    position: absolute;
    top: -10px; right: -10px; bottom: 20px; left: 20px;
    border: 2px solid var(--primary);
    z-index: -1;
    border-radius: 8px;
  }
</style>
