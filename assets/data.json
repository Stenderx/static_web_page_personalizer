{
    "_comment": "Provide your client's specific data here. The AI will read this file and inject it into the Astro components during the /implement-web-page workflow.",
    "business": {
        "name": "[Client Business Name]",
        "theme": {
            "primary": "#[Primary Brand Hex Color]",
            "headingFont": "'[Google Font Name]', serif|sans-serif"
        },
        "contact": {
            "address": "[Business Address Line 1]\n[Business Address Line 2]",
            "phone": "[Phone Number]",
            "email": "[Email Address]"
        },
        "hours": {
            "weekdays": "[Weekday Hours]",
            "weekends": "[Weekend Hours]"
        }
    },
    "hero": {
        "badge": "[Short Catchphrase/Est. Date]",
