            "[First paragraph of the business story.]",
            "[Second paragraph detailing the mission or quality.]"
        ],
        "signature": {
            "role": "[Role of the founder/owner]",
            "name": "[Name of the founder/owner]"
        },
        "image": "[about-image-filename.png]"
    },
    "location": {
        "eyebrow": "[Location Eyebrow Text - optional]",
