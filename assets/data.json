        "paragraphs": [
            "[Description of the physical location or surroundings.]"
        ],
        "features": [
            {
                "title": "[Feature 1, e.g., Free Parking]",
                "description": "[Description 1]"
            },
            {
                "title": "[Feature 2, e.g., Historic Center]",
                "description": "[Description 2]"
            }
        ],
        "image": "[location-image-filename.png]"
    },
    "gallery": {
        "eyebrow": "[Gallery/Menu Eyebrow Text]",
        "title": "[Gallery/Menu Main Title]",
        "description": "[Short description of the products or services below.]",
        "items": [
            {
                "image": "[item1-filename.png]",
                "title": "[Item 1 Title]",
                "description": "[Item 1 Description]"
            }
        ]
    }
